      "depthRangeMin": 500,
      "depthRangeMax": 2000
    },
    "hikCamera": {
      "captureTimeoutMs": 1000,
      "exposureTimeUs": 50000,
      "gain": 0.0
    }
  },

  "algorithmConfig": {
    "lbn": { "enabled": true, "timeoutMs": 2000, "confidenceThreshold": 0.8 },
    "lb": { "enabled": true, "timeoutMs": 1500, "minFeaturePoints": 50 },
    "bevel": { "enabled": true, "timeoutMs": 10000, "qualityThreshold": 0.7 }
  },

  "dataManagement": {
    "savePointClouds": true,
    "saveRawImages": true,
    "saveIntermediateResults": true,
    "outputDirectory": "./scan_results",
