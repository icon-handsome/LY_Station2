  "executionConfig": {
    "executeAllPaths": false, 
    "description": "是否执行所有启用的路径，false 表示仅执行 selectedPathIds 中指定的路径",
    "selectedPathIds": [1, 2],
    "pathExecutionOrder": "sequential",
    "allowPathSkipOnError": false,  
    "description2": "路径执行顺序：sequential(顺序) 或 parallel(并行，暂不支持)"
  },

  "turntableConfig": {
    "enabled": true,
    "description": "转盘是否启用；转动角度由 LBN 运行时解算，点位仅配置 needRotation"
  },

  "captureConfig": {
    "mechEye": {
      "capture3DTimeoutMs": 5000,
      "capture2DTimeoutMs": 3000,
      "depthRangeMin": 500,
      "depthRangeMax": 2000,
      "description": "Mech-Eye 相机采集配置：3D超时、2D超时、深度范围(mm)"
    },
    "hikCamera": {
      "captureTimeoutMs": 1000,
      "exposureTimeUs": 1307379,
      "gain": 0.0,
      "description": "海康相机采集配置：超时(ms)、曝光时间(us)、增益(dB)"
    }
  },

  "algorithmConfig": {
    "lbn": {
      "enabled": true,
      "timeoutMs": 2000,
      "confidenceThreshold": 0.8,
      "description": "LBN 算法配置：是否启用、超时、置信度阈值"
    },
    "lb": {
      "enabled": true,
      "timeoutMs": 1500,
      "minFeaturePoints": 50,
      "description": "LB 双目跟踪算法配置：是否启用、超时、最小特征点数"
    },
    "lanyou": {
      "enabled": true,
      "timeoutMs": 10000,
      "qualityThreshold": 0.7,
      "description": "蓝友最终解算算法配置：是否启用、超时、质量阈值"
    }
  },

  "dataManagement": {
    "savePointClouds": true,
    "saveRawImages": true,
    "saveIntermediateResults": true,
    "outputDirectory": "./scan_results",
    "maxStorageDays": 30,
    "description": "数据管理配置：是否保存点云、原始图像、中间结果，输出目录，最大保存天数"
