<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Label="UserMacros">
    <PCL_ROOT>F:\software install\PCL 1.8.0</PCL_ROOT>
    <PCL_3RDPARTY_ROOT>$(PCL_ROOT)\3rdParty</PCL_3RDPARTY_ROOT>
  </PropertyGroup>
  <PropertyGroup>
    <IncludePath>$(PCL_ROOT)\include\pcl-1.8;$(PCL_3RDPARTY_ROOT)\Eigen\eigen3;$(PCL_3RDPARTY_ROOT)\Boost\include\boost-1_59;$(PCL_3RDPARTY_ROOT)\FLANN\include;$(PCL_3RDPARTY_ROOT)\Qhull\include;$(PCL_3RDPARTY_ROOT)\VTK\include\vtk-7.0;$(PCL_3RDPARTY_ROOT)\OpenNI2\Include;$(IncludePath)</IncludePath>
    <LibraryPath>$(PCL_ROOT)\lib;$(PCL_3RDPARTY_ROOT)\Boost\lib;$(PCL_3RDPARTY_ROOT)\FLANN\lib;$(PCL_3RDPARTY_ROOT)\Qhull\lib;$(PCL_3RDPARTY_ROOT)\VTK\lib;$(PCL_3RDPARTY_ROOT)\OpenNI2\Lib;$(LibraryPath)</LibraryPath>
    <ExecutablePath>$(PCL_ROOT)\bin;$(PCL_3RDPARTY_ROOT)\Boost\lib;$(PCL_3RDPARTY_ROOT)\FLANN\bin;$(PCL_3RDPARTY_ROOT)\Qhull\bin;$(PCL_3RDPARTY_ROOT)\VTK\bin;$(PCL_3RDPARTY_ROOT)\OpenNI2\Redist;$(ExecutablePath)</ExecutablePath>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <PreprocessorDefinitions>_CRT_SECURE_NO_WARNINGS;NOMINMAX;BOOST_USE_WINDOWS_H;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <ForcedIncludeFiles>$(ProjectDir)include\LegacyPclBoostCompat.h;%(ForcedIncludeFiles)</ForcedIncludeFiles>
      <DisableSpecificWarnings>4996;4819;%(DisableSpecificWarnings)</DisableSpecificWarnings>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <Link>
      <AdditionalDependencies>pcl_common_debug.lib;pcl_io_debug.lib;pcl_filters_debug.lib;pcl_kdtree_debug.lib;pcl_search_debug.lib;pcl_registration_debug.lib;pcl_sample_consensus_debug.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'!='Debug'">
    <Link>
      <AdditionalDependencies>pcl_common_release.lib;pcl_io_release.lib;pcl_filters_release.lib;pcl_kdtree_release.lib;pcl_search_release.lib;pcl_registration_release.lib;pcl_sample_consensus_release.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
</Project>
