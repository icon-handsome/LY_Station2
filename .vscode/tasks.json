{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure (Ninja Debug)",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "${workspaceFolder}/tools/scan_tracking_dev.cmd",
        "configure-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Build (Ninja Debug)",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "${workspaceFolder}/tools/scan_tracking_dev.cmd",
        "build-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Run scan-tracking (Debug)",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "${workspaceFolder}/tools/scan_tracking_dev.cmd",
        "run-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "close": false
      },
      "problemMatcher": []
    },
    {
      "label": "Build and Run (Debug)",
      "dependsOn": [
        "Build (Ninja Debug)",
        "Run scan-tracking (Debug)"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Configure (Ninja Release)",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "${workspaceFolder}/tools/scan_tracking_dev.cmd",
        "configure-release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Build (Ninja Release)",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "${workspaceFolder}/tools/scan_tracking_dev.cmd",
        "build-release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "build"
    },
    {
      "label": "Run scan-tracking (Release)",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "${workspaceFolder}/tools/scan_tracking_dev.cmd",
        "run-release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "close": false
      },
      "problemMatcher": []
    },
    {
      "label": "Refresh compile_commands (clangd)",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "${workspaceFolder}/tools/scan_tracking_dev.cmd",
        "configure-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": [],
      "group": "none"
    },
    {
      "label": "Rebuild (Ninja Debug)",
      "dependsOn": [
        "Clean Build Directory (Debug)",
        "Configure (Ninja Debug)",
        "Build (Ninja Debug)"
      ],
      "dependsOrder": "sequence",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "build"
    },
    {
      "label": "Clean Build Directory (Debug)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "$target = Resolve-Path -LiteralPath '${workspaceFolder}/build/win-msvc2019-qtcore-ninja-debug' -ErrorAction SilentlyContinue; if ($target) { Remove-Item -LiteralPath $target.Path -Recurse -Force }"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
