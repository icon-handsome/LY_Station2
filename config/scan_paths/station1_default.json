    "pathExecutionOrder": "sequential",
    "allowPathSkipOnError": false
  },

  "turntableConfig": {
    "enabled": false,
    "description": "无转盘转动位，各段均为 3D 扫描"
  },

  "captureConfig": {
    "mechEye": {
      "capture3DTimeoutMs": 5000,
